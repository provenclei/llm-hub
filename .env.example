> **IMPORTANT**: This file contains sensitive configuration. DO NOT commit to version control!

# 环境变量配置

## 应用基础配置
NODE_ENV=development
APP_NAME=llm-hub
APP_PORT=3000
APP_URL=http://localhost:3000

## 数据库配置
DATABASE_URL=postgresql://llmhub_user:your_secure_password@localhost:5432/llmhub
REDIS_URL=redis://localhost:6379

## JWT密钥
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

## 上游模型提供商API密钥
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-org-id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-key

# 国产模型
BAIDU_API_KEY=your-baidu-key
BAIDU_SECRET_KEY=your-baidu-secret

ALIBABA_API_KEY=your-alibaba-key

# 其他渠道（可选）
CUSTOM_CHANNEL_KEY=your-custom-key

## 计费配置
MARKUP_RATE=1.5                    # 加价倍数
DEFAULT_CURRENCY=CNY               # 默认货币
BILLING_CYCLE=monthly              # 计费周期
FREE_TIER_TOKENS=100000            # 免费额度

## 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_RPM=60          # 默认每分钟请求数
RATE_LIMIT_DEFAULT_TPM=100000      # 默认每分钟token数

## 监控配置
LOG_LEVEL=info
METRICS_ENABLED=true
SENTRY_DSN=                        # 可选：Sentry错误追踪

## 邮件配置（用于账单通知）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
